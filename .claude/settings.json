{
  "permissions": {
    "allow": [
      "Bash(pkill -9 -f \"vite\")",
      "Bash(npm run *)",
      "Bash(disown)",
      "mcp__playwright__browser_close",
      "Bash(pkill -f \"ms-playwright/mcp-chrome\")",
      "Bash(pkill -f \"chrome.*--user-data-dir.*mcp-chrome\")",
      "Read(//home/node/.cache/ms-playwright/**)",
      "Bash(rm -rf /home/node/.cache/ms-playwright/mcp-chrome-04cc2ea/SingletonLock /home/node/.cache/ms-playwright/mcp-chrome-04cc2ea/SingletonSocket /home/node/.cache/ms-playwright/mcp-chrome-04cc2ea/SingletonCookie 2>/dev/null; echo done)"
    ],
    "additionalDirectories": [
      "/home/node/.cache/ms-playwright/mcp-chrome-04cc2ea"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/Space-Ship-Network/.claude/hooks/block-sensitive-files.sh",
            "statusMessage": "機密ファイルチェック中..."
          }
        ]
      }
    ]
  }
}
